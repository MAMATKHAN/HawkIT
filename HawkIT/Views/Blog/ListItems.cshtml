@model IEnumerable<Article>
@section Styles{<link rel="stylesheet" href="~/css/ListItems.css"/>}

@*   локация -- где находится пользователь   *@

<div class="locat">
	<a asp-controller="Home" asp-action="Index" class="locat__main">Главная </a>
	<img src="~/img/blog_strelocka.png" class="locat__img"/>
	<a class="locat__case">Блог</a>
</div>



@*   баннер   *@

<img src="~/img/blog__banner.png" class="banner"/>


<div class="txt">Привет, Целевая аудитория! Вас ждут айти-рубрики, полезные советы для новичков, свежие обновления и море крутого контента!</div>



@*   карточки со статьями в блоге   *@


<div class="blog">
	<div class="blog__title">
		<div class=" blog__title__txt">Блог</div>

		@*   combobox   *@

		<div class="combobox">
			<div class="combobox__inner">
				<div class="combobox__inner__txt">Сортировать по</div>
				<img src="~/img/combobox_strel.svg" class="combobox__inner__btn" src=""/>
			</div>

			<div class="combobox__list combobox__list__anime">

				@*   выпадающий список   *@

				<div class="combobox__list__item">Дизайну</div>
				<div class="combobox__list__item">Фронтенду</div>
				<div class="combobox__list__item">Бэкенду</div>
			</div>
		</div>
	</div>

	<div class="blog__cardlist">
		@foreach(var article in Model) 
		{
			@*   Карточки со статьями в блоге   *@
		
			<a asp-controller="Blog" asp-action="Details" asp-route-id="@article.Id" class="blog__card">
				<img src="@article.ArticleImage" class="blog__card__img"/>
				<div class="blog__card__txt">@article.Name</div>
				<div class="blog__card__desc">
					<div class="blog__card__desc__date">@article.CreatedDate.ToShortDateString()</div>
					@if(article.Tags != null)
					{
						@foreach (var tag in article.Tags)
						{
							<span class="blog__card__desc__type">@tag.Name </span>
						}
					}
				</div>
			</a>
		}
	</div>
</div>







@section Scripts{<script src="~/js/blog.js"></script>}