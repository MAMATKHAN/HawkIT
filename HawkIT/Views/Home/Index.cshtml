@{
    ViewData["Title"] = "Home Page";
}

@section Styles{<link rel="stylesheet" href="~/css/main.css" />}


@*  intro   *@


<div class="intro">
    <img src="~/img/intro.gif" class="intro__gif"/>

    <img src="~/img/intro_logo.svg" class="intro__logo"/>

    <div class="intro__txt">Студия разработки цифровых продуктов</div>

    <div class="intro__mouse">
        <div class="intro__mouse__scroll"></div>
    </div>
</div>



@*  made  *@


<div class="made">
    <div class="made__txt">Разработано в студии</div>

    <div class="made__btn__line">

        @*  button__type2   *@

        <div class="button__type2 type2__active">Все</div>

        <div class="button__type2">Веб-приложения</div>

        <div class="button__type2">Мобильные приложение</div>

        <div class="button__type2">Аналитика</div>

        <div class="button__type2">Дизайн интерфейсов</div>

        <div class="button__type2">Редизайн</div>

        <div class="button__type2">Инфографика</div>

        <div class="button__type2">Логотипы</div>
    </div>

</div>
